config_version=5

[application]

config/name="SpinToWinTab"
run/main_scene="uid://hrvq4vulkxkk"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SteamManager="*uid://bwlpfalymbk0f"
SceneManager="*uid://bkf6vbeyuybxc"
GameState="*uid://bmyj6osyqihy4"
MinigameManager="*uid://rdtw5jy7uc07"

[display]

